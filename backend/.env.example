# Puerto donde corre el servidor Express
PORT=3001

# URL de conexión a PostgreSQL
# En Railway se genera automáticamente al crear la base de datos
DATABASE_URL="postgresql://usuario:contraseña@host:5432/gestor_eventos"

# Secreto para firmar los JWT (auth)
# Debe ser una cadena larga y aleatoria — nunca compartir en producción
JWT_SECRET="cambia_esto_por_un_secreto_seguro"

# Entorno de ejecución
NODE_ENV="development"
