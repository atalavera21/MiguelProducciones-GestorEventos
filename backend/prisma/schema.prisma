generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// Valores fijos que no cambian con el negocio.
// Los catálogos administrables (tipos_evento, tipos_servicio) son tablas, no enums.
// ─────────────────────────────────────────────

// Estimación visual para análisis de negocio — no se le pide DNI al cliente
// @map permite que el DB almacene "18-30" aunque en TypeScript usemos RangoEdad.JOVEN
enum RangoEdad {
  JOVEN  @map("18-30")
  ADULTO @map("30-45")
  MAYOR  @map("45+")

  @@map("rango_edad")
}

// Solo aplica cuando esFisica = true en detalle_fotografia
enum TipoPapel {
  BRILLO
  MATE

  @@map("tipo_papel")
}

// Formas de pago aceptadas
enum MetodoPago {
  EFECTIVO
  YAPE
  TRANSFERENCIA

  @@map("metodo_pago")
}

// ─────────────────────────────────────────────
// CATÁLOGOS
// Tablas administrables — se pueden agregar o desactivar registros sin cambiar código.
// Equivalen a tablas de lookup en .NET con su propio repositorio.
// ─────────────────────────────────────────────

// Tipos de evento que ofrece Miguel Producciones (Boda, Quinceañera, etc.)
model TipoEvento {
  id     Int     @id @default(autoincrement()) @db.SmallInt
  nombre String  @db.VarChar(100)
  activo Boolean @default(true)

  eventos Evento[]

  @@map("tipos_evento")
}

// Servicios que ofrece la empresa (Fotografía, Filmación, Cuadro Firma, etc.)
model TipoServicio {
  id          Int     @id @default(autoincrement()) @db.SmallInt
  nombre      String  @db.VarChar(100)
  descripcion String? @db.VarChar(200)
  activo      Boolean @default(true)

  eventoServicios EventoServicio[]

  @@map("tipos_servicio")
}

// Estados del ciclo de vida de un contrato
// Pendiente → Activo → PendienteEntrega → Terminado
// Pendiente → Cancelado / Activo → Cancelado
model EstadoContrato {
  id     Int    @id @default(autoincrement()) @db.SmallInt
  nombre String @db.VarChar(50)

  contratos Contrato[]

  @@map("estados_contrato")
}

// ─────────────────────────────────────────────
// ENTIDADES PRINCIPALES
// ─────────────────────────────────────────────

model Cliente {
  id         Int       @id @default(autoincrement())
  nombre     String    @db.VarChar(150)
  telefono   String    @db.VarChar(30)
  dni        String    @db.VarChar(12)
  referencia String?   @db.VarChar(200)  // Ej: "Referido por García", "Facebook"
  sexo       Boolean                     // true = masculino / false = femenino
  rangoEdad  RangoEdad
  activo     Boolean   @default(true)    // false = archivado, no aparece en listas activas

  eventos Evento[]

  @@map("clientes")
}

// Centro del sistema — todo contrato se genera desde un evento
model Evento {
  id           Int      @id @default(autoincrement())
  idCliente    Int
  idTipoEvento Int      @db.SmallInt
  direccion    String   @db.VarChar(300)
  fechaHora    DateTime
  notas        String?

  cliente    Cliente      @relation(fields: [idCliente], references: [id])
  tipoEvento TipoEvento   @relation(fields: [idTipoEvento], references: [id])
  servicios  EventoServicio[]
  contrato   Contrato?       // Un evento tiene como máximo un contrato

  @@map("eventos")
}

// Tabla intermedia entre eventos y tipos_servicio.
// Registra qué servicios tiene el evento y a qué precio se acordó cada uno.
model EventoServicio {
  id             Int     @id @default(autoincrement())
  idEvento       Int
  idTipoServicio Int     @db.SmallInt
  precio         Decimal @db.Decimal(10, 2)

  evento              Evento              @relation(fields: [idEvento], references: [id])
  tipoServicio        TipoServicio        @relation(fields: [idTipoServicio], references: [id])
  detalleFotografia   DetalleFotografia?
  detalleFilmacion    DetalleFilmacion?
  detalleCuadroFirma  DetalleCuadroFirma?

  @@map("evento_servicios")
}

model DetalleFotografia {
  id               Int        @id @default(autoincrement())
  idEventoServicio Int        @unique  // 1:1 con EventoServicio
  esDigital        Boolean    @default(true)
  esFisica         Boolean    @default(false)
  tipoPapel        TipoPapel?           // Solo si esFisica = true
  notas            String?    @db.VarChar(300)

  eventoServicio EventoServicio @relation(fields: [idEventoServicio], references: [id])

  @@map("detalle_fotografia")
}

model DetalleFilmacion {
  id               Int     @id @default(autoincrement())
  idEventoServicio Int     @unique
  incluyeHighlight Boolean @default(true)
  notas            String? @db.VarChar(300)

  eventoServicio EventoServicio @relation(fields: [idEventoServicio], references: [id])

  @@map("detalle_filmacion")
}

model DetalleCuadroFirma {
  id               Int    @id @default(autoincrement())
  idEventoServicio Int    @unique
  descripcion      String @db.VarChar(300)

  eventoServicio EventoServicio @relation(fields: [idEventoServicio], references: [id])

  @@map("detalle_cuadrofirma")
}

// El contrato desnormaliza datos del cliente y del evento al momento de su creación.
// Garantiza que el PDF refleje el acuerdo exactamente como fue firmado,
// aunque después se editen el cliente o el evento.
model Contrato {
  id              Int        @id @default(autoincrement())
  idEvento        Int        @unique  // Un evento tiene máximo un contrato
  idEstado        Int        @db.SmallInt

  // Datos del cliente — copiados al momento de la firma
  nombreCliente   String     @db.VarChar(150)
  dniCliente      String     @db.VarChar(12)
  telefonoCliente String     @db.VarChar(30)

  // Datos del evento — copiados al momento de la firma
  tipoEvento      String     @db.VarChar(100)
  direccionEvento String     @db.VarChar(300)
  fechaHoraEvento DateTime

  // Montos en Soles (PEN)
  montoTotal      Decimal    @db.Decimal(10, 2)
  montoAdelanto   Decimal    @db.Decimal(10, 2)
  saldo           Decimal    @db.Decimal(10, 2)

  // Pago
  metodoPago      MetodoPago
  cuentaPago      String     @db.VarChar(100)

  // Firma
  dniFotografo    String     @db.VarChar(12)
  fechaContrato   DateTime   @db.Date
  pdfUrl          String?    @db.VarChar(500)

  evento  Evento         @relation(fields: [idEvento], references: [id])
  estado  EstadoContrato @relation(fields: [idEstado], references: [id])

  @@map("contratos")
}

// Documento de cotización independiente — sin relación con ninguna otra tabla.
// El campo servicios usa Json (JSONB en PostgreSQL) por diseño deliberado:
// acepta cualquier combinación de servicios sin restricciones de esquema.
model Proforma {
  id            Int      @id @default(autoincrement())
  nombreCliente String   @db.VarChar(150)
  tipoEvento    String   @db.VarChar(100)
  fechaEvento   DateTime @db.Date
  horario       String   @db.VarChar(50)
  distrito      String   @db.VarChar(100)
  referenciaDir String?  @db.VarChar(200)
  servicios     Json                        // JSONB — lista libre de servicios cotizados
  total         Decimal  @db.Decimal(10, 2)
  adelanto      Decimal  @db.Decimal(10, 2)
  creadoEn      DateTime @default(now())

  @@map("proformas")
}
